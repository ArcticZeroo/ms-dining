model Cafe {
  // string id from buy-ondemand
  id               String  @id
  name             String
  tenantId         String
  logoName         String?
  contextId        String
  displayProfileId String
  storeId          String  @default("")
  externalName     String  @default("")

  dailyCafes        DailyCafe[]
  menuItems         MenuItem[]
  stations          Station[]
  pendingCafeOrders PendingCafeOrder[]
  cafeOrders        CafeOrder[]
}

// Represents a group of menu items or stations that are identical across multiple cafes
// e.g. "Build Your Own Burrito" is at multiple cafes with different buy-ondemand ids, but
// they are the same item as far as reviews and search are concerned. There are also variations
// of names like "BYO Burrito" that should be in the same group.
// The same is true for stations like "Diner" that are at multiple cafes.
model CrossCafeGroup {
  id         String  @id @default(uuid())
  name       String
  entityType String
  notes      String?

  menuItems MenuItem[]
  stations  Station[]
}

model MenuItem {
  // string id from buy-ondemand
  id             String  @id
  name           String
  normalizedName String  @default("")
  description    String?
  imageUrl       String?
  tags           String?
  calories       Int
  maxCalories    Int
  price          Float

  groupId String?
  group   CrossCafeGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  entityKey String @default(dbgenerated()) // generated STORED column - see migration

  // externalItemId String?
  thumbnailHash String?

  externalLastUpdateTime DateTime?
  externalReceiptText    String?

  cafeId String
  cafe   Cafe   @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  stationId String
  station   Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  dailyMenuItems        DailyMenuItem[]
  modifiers             MenuItemModifierEntry[]
  searchTags            SearchTag[]
  reviews               Review[]
  ingredientsMenuRoles  IngredientsMenuRole[]
  cartItems             CartItem[]
  pendingCafeOrderItems PendingCafeOrderItem[]
  cafeOrderItems        CafeOrderItem[]

  @@index([entityKey])
}

model MenuItemModifierEntry {
  modifierId String
  menuItemId String
  index      Int

  modifier MenuItemModifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)
  menuItem MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([modifierId, menuItemId])
}

model MenuItemTag {
  // string id from buy-ondemand
  id   String @id
  name String
}

model SearchTag {
  name String @id @unique

  menuItems MenuItem[]
}

model MenuItemModifier {
  // string id from buy-ondemand
  id          String @id
  description String
  minimum     Int
  maximum     Int
  choiceType  String

  menuItems                     MenuItemModifierEntry[]
  choices                       MenuItemModifierChoice[]
  cartItemModifierChoices       CartItemModifierChoice[]
  pendingCafeOrderItemModifiers PendingCafeOrderItemModifier[]
  cafeOrderItemModifiers        CafeOrderItemModifier[]
}

model MenuItemModifierChoice {
  // string id from buy-ondemand; not globally unique, since different
  // modifier groups can share the same set of choice IDs.
  id          String
  description String
  price       Float

  modifierId                    String
  modifier                      MenuItemModifier               @relation(fields: [modifierId], references: [id], onDelete: Cascade)

  cartItemModifierChoices       CartItemModifierChoice[]
  pendingCafeOrderItemModifiers PendingCafeOrderItemModifier[]
  cafeOrderItemModifiers        CafeOrderItemModifier[]

  @@id([id, modifierId])
}

model Station {
  // string id from buy-ondemand
  id             String  @id
  name           String
  normalizedName String  @default("")
  logoUrl        String?
  menuId         String

  // Minutes since midnight. Most cafes open at 11 AM (660) and close around 2 PM (840).
  opensAt                    Int      @default(660)
  closesAt                   Int      @default(840)
  externalMenuLastUpdateTime DateTime @default("1970-01-01T00:00:00.000Z")

  groupId String?
  group   CrossCafeGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  entityKey String @default(dbgenerated()) // generated STORED column - see migration

  cafeId String
  cafe   Cafe   @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  dailyStations DailyStation[]
  menuItems     MenuItem[]
  reviews       Review[]
  menuSnapshots StationMenuSnapshot[]

  @@index([entityKey])
}

model StationMenuSnapshot {
  // SHA-256 hash of (stationId + sorted category→menuItem content)
  id String @id

  stationId String
  station   Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  categories    DailyCategory[]
  dailyStations DailyStation[]
}

model DailyStation {
  id Int @id @default(autoincrement())

  dateString String

  stationId String
  station   Station @relation(fields: [stationId], references: [id])

  snapshotId String
  snapshot   StationMenuSnapshot @relation(fields: [snapshotId], references: [id])

  cafeId    String
  dailyCafe DailyCafe @relation(fields: [dateString, cafeId], references: [dateString, cafeId], onDelete: Cascade)

  @@index([cafeId, dateString])
  @@index([stationId, dateString])
  @@index([snapshotId])
  @@index([dateString])
}

model DailyCategory {
  id Int @id @default(autoincrement())

  name String

  snapshotId String
  snapshot   StationMenuSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  menuItems DailyMenuItem[]

  @@index([snapshotId])
}

model DailyMenuItem {
  id Int @id @default(autoincrement())

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  categoryId Int
  category   DailyCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([menuItemId])
}

model CafeShutdown {
  messageHash  String  @id
  message      String
  shutdownType String  @default("full") // full | online_ordering
  isTemporary  Boolean @default(false)
  resumeInfo   String?

  dailyCafes DailyCafe[]
}

model DailyCafe {
  dateString  String
  isAvailable Boolean @default(true)

  cafeId String
  cafe   Cafe   @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  shutdownMessageHash String?
  shutdown            CafeShutdown? @relation(fields: [shutdownMessageHash], references: [messageHash])

  dailyStations DailyStation[]

  @@id([dateString, cafeId])
}

model User {
  id          String   @id @default(uuid())
  externalId  String
  provider    String
  displayName String
  role        String   @default("user")
  createdAt   DateTime @default(now())

  favoriteStations   String?
  favoriteMenuItems  String?
  homepageIds        String?
  lastSettingsUpdate DateTime?

  reviews           Review[]
  sessions          Session[]
  cart              Cart?
  pendingCafeOrders PendingCafeOrder[]
  cafeOrders        CafeOrder[]

  @@unique([externalId, provider])
}

model Review {
  id          String   @id @default(uuid())
  // 0-10
  rating      Int
  comment     String?
  displayName String?
  createdAt   DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  stationId String?
  station   Station? @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([userId, menuItemId])
  @@unique([userId, stationId])
}

model Session {
  id        String    @id
  expiresAt DateTime? // null means no expiration - at least until we get ordering there's not really a need for expiration
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SearchQuery {
  query     String   @id
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model IngredientsMenuRole {
  id         String   @id @default(uuid())
  menuItemId String
  role       String
  menuHash   String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  metadata IngredientsMenuMetadata @relation(fields: [menuHash], references: [menuHash], onDelete: Cascade)

  @@unique([menuItemId, menuHash])
}

model IngredientsMenuMetadata {
  menuHash String @id
  price    Float

  roles IngredientsMenuRole[]
}
