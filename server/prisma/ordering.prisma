// ─── Cart ────────────────────────────────────────────────────────────
// Server-side cart replaces client localStorage. One cart per user.
// userId is the PK (one cart per user, no separate surrogate id).

model Cart {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  items CartItem[]
}

// CartItem lives in the cart while shopping, then transfers to an
// OrderCafePart at checkout. Exactly one of cartUserId / orderCafePartId
// is set at any time.
model CartItem {
  id                  String  @id @default(uuid())
  cartUserId          String?
  cart                Cart?   @relation(fields: [cartUserId], references: [userId], onDelete: Cascade)
  orderCafePartId     String?
  orderCafePart       OrderCafePart? @relation(fields: [orderCafePartId], references: [id], onDelete: Cascade)
  menuItemId          String
  menuItem            MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  quantity            Int     @default(1)
  specialInstructions String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modifierChoices CartItemModifierChoice[]
}

model CartItemModifierChoice {
  id         Int      @id @default(autoincrement())
  cartItemId String
  cartItem   CartItem @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  modifierId String
  choiceId   String

  @@unique([cartItemId, modifierId, choiceId])
}

// ─── Orders ──────────────────────────────────────────────────────────
// An OrderSession is a user-facing checkout that may span multiple cafes.
// Each cafe's Buy On Demand interaction is tracked independently as an OrderCafePart.

model OrderSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Payment identity — set when user starts payment, fixed for the session
  alias                      String?
  phoneNumberWithCountryCode String?

  cafeParts OrderCafePart[]
}

model OrderCafePart {
  id             String @id @default(uuid())
  orderSessionId String
  orderSession   OrderSession @relation(fields: [orderSessionId], references: [id], onDelete: Cascade)
  cafeId         String

  // Buy On Demand identifiers (populated after checkout calls BoD add-to-cart)
  buyOnDemandOrderId     String?
  buyOnDemandOrderNumber String?

  // State: pending → payment_pending → completed | failed | abandoned
  status String @default("pending")

  // Financial (populated from Buy On Demand response)
  subtotal Float?
  tax      Float?
  total    Float?

  // Wait time (from Buy On Demand API at close time)
  waitTimeMin Int?
  waitTimeMax Int?

  // Serialized session state needed to rebuild the CafeOrderSession
  // if the in-memory session expires. Contains ordering context, pay config,
  // order details, site store info, etc. (~5KB JSON)
  sessionStateJson String?

  // Error tracking
  lastError String?
  lastStage String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  // Items transferred from the cart at checkout
  items CartItem[]
}
