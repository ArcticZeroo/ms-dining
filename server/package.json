  "scripts": {
    "start": "npx tsc && node dist/preflight.js && node dist/main/main.js",
    "start-dev": "npx tsc && node dist/preflight.js --allow-empty && node --trace-warnings dist/main/main.js",
    "dev": "npx cross-env NODE_ENV=dev FAKE_ORDERING=true npm run start-dev",
    "build": "npx tsc --project ../common/tsconfig.json && npx tsc",
    "preflight": "node dist/preflight.js",
    "predeploy": "npx tsc --project ../common/tsconfig.json && npx prisma migrate deploy && npx prisma generate",
    "deploy": "npm run predeploy && npm run start",
    "deploy-dev": "npm run predeploy && npm run start-dev",
    "test": "npx tsc && node --test --test-force-exit dist/**/*.test.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  }
}
